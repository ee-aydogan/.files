#!/usr/bin/env bash
set -euo pipefail

ROOT="$HOME/.files"
CONFIG="$HOME/.config"
LINKS="$ROOT/links.json"

jq -c '.[]' "$LINKS" | while read -r entry; do
  src=$(jq -r '.src' <<<"$entry")
  dst=$(jq -r '.dst' <<<"$entry")
  root=$(jq -r '.root // "config"' <<<"$entry")

  target="$ROOT/$src"
  [[ "$root" == "home" ]] && link="$HOME/$dst" || link="$CONFIG/$dst"

  [[ -e "$link" || -L "$link" ]] && rm -rf "$link"
  mkdir -p "$(dirname "$link")"
  ln -s "$target" "$link"
  printf '  %s \e[2m→\e[22m %s\n' "$src" "$link"
done
